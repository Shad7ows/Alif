استورد الرياضيات, العشوائي

صنف شبكة_عصبية_بسيطة:
	دالة __تهيئة__(هذا, حجم_المدخلات=27, حجم_الطبقات_المخفية=64, حجم_المخرجات=9):
		هذا.معدل_التعلم = 0.01
		الانحراف_المعياري_مدخلات_لمخفي = الرياضيات.جذر(2.0 \ حجم_المدخلات)
		الانحراف_المعياري_مخفي_لمخرجات = الرياضيات.جذر(2.0 \ حجم_الطبقات_المخفية)
		
		هذا.الاوزان_مدخلات_لمخفي = [[العشوائي.توزيع_طبيعي(0, الانحراف_المعياري_مدخلات_لمخفي) لكل _ في مدى(حجم_الطبقات_المخفية)] لكل _ في مدى(حجم_المدخلات)]
		هذا.الاوزان_مخفي_لمخرجات = [[العشوائي.توزيع_طبيعي(0, الانحراف_المعياري_مخفي_لمخرجات) لكل _ في مدى(حجم_المخرجات)] لكل _ في مدى(حجم_الطبقات_المخفية)]
		هذا.ازاحات_المخفية = [0.01] * حجم_الطبقات_المخفية
		هذا.ازاحات_المخرجات = [0.01] * حجم_المخرجات

	دالة تقدم(هذا, المدخلات):
		هذا.مدخلات_طبقة_مخفية = [اجمع(المدخلات[س] * هذا.الاوزان_مدخلات_لمخفي[س][ص] لكل س في مدى(طول(المدخلات))) + هذا.ازاحات_المخفية[ص] لكل ص في مدى(طول(هذا.ازاحات_المخفية))]
		هذا.مخرجات_طبقة_مخفية = [اقصى(0.0, س) لكل س في هذا.مدخلات_طبقة_مخفية]
		هذا.مدخلات_طبقة_مخرجات = [اجمع(هذا.مخرجات_طبقة_مخفية[ص] * هذا.الاوزان_مخفي_لمخرجات[ص][ش] لكل ص في مدى(طول(هذا.مخرجات_طبقة_مخفية))) + هذا.ازاحات_المخرجات[ش] لكل ش في مدى(طول(هذا.ازاحات_المخرجات))]
		
		اقصى_قيمة = اقصى(هذا.مدخلات_طبقة_مخرجات)
		اسيات = [الرياضيات.اس_طبيعي(س - اقصى_قيمة) لكل س في هذا.مدخلات_طبقة_مخرجات]
		مجموع_الاسيات = اجمع(اسيات)
		ارجع [س \ مجموع_الاسيات لكل س في اسيات]

	دالة تدريب(هذا, المدخلات, مؤشر_الهدف):
		المخرجات = هذا.تقدم(المدخلات)
		طبقة_مخرجات_خطأ = [مخرج - (1.0 اذا س == مؤشر_الهدف والا 0.0) لكل س, مخرج في تعداد(المخرجات)]
		طبقة_مخفية_خطأ = [اجمع(طبقة_مخرجات_خطأ[ش] * هذا.الاوزان_مخفي_لمخرجات[ض][ش] لكل ش في مدى(طول(المخرجات))) * (1.0 اذا هذا.مدخلات_طبقة_مخفية[ض] > 0 والا 0.0) لكل ض في مدى(طول(هذا.مخرجات_طبقة_مخفية))]
		
		لكل ض في مدى(طول(هذا.مخرجات_طبقة_مخفية)):
			لكل ش في مدى(طول(المخرجات)):
				هذا.الاوزان_مخفي_لمخرجات[ض][ش] -= هذا.معدل_التعلم * طبقة_مخرجات_خطأ[ش] * هذا.مخرجات_طبقة_مخفية[ض]
		هذا.ازاحات_المخرجات = [ب - هذا.معدل_التعلم * الخطأ لكل ب, الخطأ في مقرون(هذا.ازاحات_المخرجات, طبقة_مخرجات_خطأ)]
		
		لكل س في مدى(طول(المدخلات)):
			لكل ص في مدى(طول(هذا.مخرجات_طبقة_مخفية)):
				هذا.الاوزان_مدخلات_لمخفي[س][ص] -= هذا.معدل_التعلم * طبقة_مخفية_خطأ[ص] * المدخلات[س]
		هذا.ازاحات_المخفية = [ب - هذا.معدل_التعلم * الخطأ لكل ب, الخطأ في مقرون(هذا.ازاحات_المخفية, طبقة_مخفية_خطأ)]
		
		ارجع -الرياضيات.لوغ(المخرجات[مؤشر_الهدف] + 0.00000001)

صنف اكس_او:
	توليفات_الفوز = ((0, 1, 2), (3, 4, 5), (6, 7, 8), (0, 3, 6), (1, 4, 7), (2, 5, 8), (0, 4, 8), (2, 4, 6))
	
	دالة __تهيئة__(هذا):
		هذا.اللوح = [0] * 9
		هذا.اللاعب = 1
	
	@خاصية
	دالة الحركات_المتاحة(هذا):
		ارجع [س لكل س, خلية في تعداد(هذا.اللوح) اذا خلية == 0]
		
	@خاصية
	دالة الفائز(هذا):
		لكل أ, ب, ت في هذا.توليفات_الفوز:
			اذا هذا.اللوح[أ] == هذا.اللوح[ب] == هذا.اللوح[ت] != 0:
				ارجع هذا.اللوح[أ]
		ارجع 0 اذا 0 ليس في هذا.اللوح والا -1
		
	@خاصية
	دالة هل_انتهى(هذا):
		ارجع هذا.الفائز != -1
		
	دالة حرك(هذا, الموقع):
		اذا 0 <= الموقع < 9 و هذا.اللوح[الموقع] == 0:
			هذا.اللوح[الموقع] = هذا.اللاعب
			هذا.اللاعب = 3 - هذا.اللاعب
			ارجع صح
		ارجع خطا
		
	دالة اجلب_الحالة(هذا, منظور_اللاعب):
		ارجع [قيمة لكل خلية في هذا.اللوح لكل قيمة في ([1, 0, 0] اذا خلية == 0 والا [0, 1, 0] اذا خلية == منظور_اللاعب والا [0, 0, 1])]
		
	دالة اعرض(هذا):
		جدول = {0: " ", 1: "X", 2: "O"}
		اطبع("\ساللوح:         الموقع:")
		لكل س في مدى(0, 9, 3):
			اطبع(م" {جدول[هذا.اللوح[س]]} | {جدول[هذا.اللوح[س + 1]]} | {جدول[هذا.اللوح[س + 2]]}      {س} | {س+1} | {س+2}")
			اذا س < 6:
				اطبع("-----------    -----------")

دالة اجلب_معلومات_الفائز(اللوح):
	لكل أ, ب, ت في اكس_او.توليفات_الفوز:
		اذا اللوح[أ] == اللوح[ب] == اللوح[ت] != 0:
			ارجع اللوح[أ]
	ارجع 0 اذا 0 ليس في اللوح والا -1

دالة ادنى_اقصى(اللوح, العمق, هل_أقصى, اللاعب):
	الفائز = اجلب_معلومات_الفائز(اللوح)
	اذا الفائز == اللاعب:
		ارجع 10 - العمق
	اذا الفائز == 3 - اللاعب:
		ارجع العمق - 10
	اذا الفائز == 0:
		ارجع 0
	
	الافضل = -عشري("لانهائي") اذا هل_أقصى والا عشري("لانهائي")
	اللاعب_المستهدف = اللاعب اذا هل_أقصى والا 3 - اللاعب
	
	لكل س في مدى(9):
		اذا اللوح[س] == 0:
			اللوح[س] = اللاعب_المستهدف
			النقاط = ادنى_اقصى(اللوح, العمق + 1, ليس هل_أقصى, اللاعب)
			اللوح[س] = 0
			الافضل = اقصى(الافضل, النقاط) اذا هل_أقصى والا ادنى(الافضل, النقاط)
	ارجع الافضل	
	
دالة اجلب_افضل_حركة(اللوح, اللاعب):
	افضل_قيمة, افضل_حركة = -عشري("لانهائي"), -1
	لكل س في مدى(9):
		اذا اللوح[س] == 0:
			اللوح[س] = اللاعب
			قيمة_الحركة = ادنى_اقصى(اللوح, 0, خطأ, اللاعب)
			اللوح[س] = 0
			اذا قيمة_الحركة > افضل_قيمة:
				افضل_قيمة, افضل_حركة = قيمة_الحركة, س
	ارجع افضل_حركة

دالة توليد_بيانات_التدريب(عدد_اللعبات):
	مجموعة_البيانات = []
	اطبع(م"\ستوليد {عدد_اللعبات} لعبة باستخدام خوارزمية 'Minimax' الرجاء الإنتظار...")
	
	لكل مؤشر_لعبة في مدى(عدد_اللعبات):
		اللوح = [0] * 9
		اللاعب = 1
		بينما اجلب_معلومات_الفائز(اللوح) == -1:
			افضل_حركة = اجلب_افضل_حركة(اللوح, اللاعب)
			الحالة = [قيمة لكل خلية في اللوح لكل قيمة في (
			[1,0,0] اذا خلية == 0 والا [0,1,0] اذا خلية == اللاعب والا [0,0,1]
			)]
			مجموعة_البيانات.اضف({"الحالة": الحالة, "الهدف": افضل_حركة})
			الحركات_المتاحة = [س لكل س, ص في تعداد(اللوح) اذا ص==0]
			اللوح[العشوائي.اختيار(الحركات_المتاحة)] = اللاعب
			اللاعب = 3 - اللاعب
			
		التقدم = صحيح(((مؤشر_لعبة + 1) \ عدد_اللعبات) * 40)
		الشريط = '█' * التقدم + '-' * (40 - التقدم)
		النسبة = ((مؤشر_لعبة + 1) \ عدد_اللعبات) * 100
		اطبع(م"\ر[{الشريط}] {مؤشر_لعبة + 1} \ {عدد_اللعبات} ({النسبة:.1ف}%)", النهاية="", مباشر=صح)
		
	اطبع("\ستم توليد البيانات بنجاح.")
	ارجع مجموعة_البيانات
		

دالة درب_الشبكة(بيانات_التدريب, اقصى_فترة):
	شبكة_عصبية = شبكة_عصبية_بسيطة()
	اطبع(م"\ستم تحميل {طول(بيانات_التدريب)} عينة, سيبدأ التدريب لـفترة {اقصى_فترة} لاستهداف الخسارة 0.01 ...")
	لكل فترة في مدى(اقصى_فترة):
		العشوائي.خلط(بيانات_التدريب)
		
		اذا فترة > اقصى_فترة * 0.3:
			شبكة_عصبية.معدل_التعلم = 0.005
		اذا فترة > اقصى_فترة * 0.6:
			شبكة_عصبية.معدل_التعلم = 0.001
		
		حزمة = بيانات_التدريب[:1000]
		الفقد_الكلي = اجمع(شبكة_عصبية.تدريب(عنصر["الحالة"], عنصر["الهدف"]) لكل عنصر في حزمة)
		متوسط_الفقد = الفقد_الكلي \ طول(حزمة)
		
		اذا فترة \\ 20 == 0 او فترة == اقصى_فترة - 1:
			طول_الشريط = 20
			التقدم = (فترة + 1) \ اقصى_فترة
			كتلة = صحيح(قرب(طول_الشريط * التقدم))
			شريط = "█" * كتلة + "░" * (طول_الشريط - كتلة)
			
			اطبع(م"\رالفترة {فترة:03ع}\\{اقصى_فترة} | الفقد: {متوسط_الفقد:.5ف} | معدل_التعلم: {شبكة_عصبية.معدل_التعلم:.3ف} | [{شريط}] {التقدم * 100:.0ف}%", النهاية="", مباشر=صح)
			
		اذا متوسط_الفقد <= 0.01:
			اطبع(م"\ستم الوصول إلى الفقد المستهدف عند الفترة {فترة}. الفقد: {متوسط_الفقد:.5ف}")
			توقف
	
	ارجع شبكة_عصبية
		
دالة العب(شبكة_مدربة):
	اللعبة = اكس_او()

	بينما ليس اللعبة.هل_انتهى:
		اللعبة.اعرض()
		
		اذا اللعبة.اللاعب == 1:
			حاول:
				حركة = صحيح(ادخل("\سادخل حركتك (0-8): "))
				اذا حركة ليس في اللعبة.الحركات_المتاحة:
					اطلق خطأ_قيمة
				اللعبة.حرك(حركة)
			خلل خطأ_قيمة:
				اطبع("ادخال غير صحيح, اختر رقم بين 0-8 فقط.")
		والا:
			اطبع("\سالذكاء الإصطناعي يفكر...")
			الحالة = اللعبة.اجلب_الحالة(2)
			التنبؤ = شبكة_مدربة.تقدم(الحالة)
			
			افضل_حركة = اقصى(اللعبة.الحركات_المتاحة, مفتاح=خطية ص: التنبؤ[ص])
			اطبع(م"الذكاء الإصطناعي اختار: {افضل_حركة} (اليقين: {التنبؤ[افضل_حركة]:.2ف})")
			اللعبة.حرك(افضل_حركة)
			
	اللعبة.اعرض()
	رسالة_الفوز = {0: "تعادل 🤝 اعد المحاولة", 1: "لقد فزت 🎉 مبارك لك", 2: "لقد خسرت 👎, حظ اوفر في المرة القادمة"}
	اطبع(م"\س{رسالة_الفوز[اللعبة.الفائز]}")
		

دالة اجلب_ادخال_صحيح(التلقينة, القيمة):
	المدخلات = ادخل(التلقينة)
	اذا ليس المدخلات:
		ارجع القيمة
	حاول:
		ارجع صحيح(المدخلات)
	خلل خطأ_قيمة:
		اطبع(م"خطأ في المدخلات, سيتم تمرير القيمة الإفتراضية {القيمة}.")
		ارجع القيمة




اطبع(م"{' لعبة اكس-او مدربة بالشبكات العصبية بإستخدام "الوحدة الخطية المعدلة ReLU" ':=^90}")

عدد_لعبات_التدريب = اجلب_ادخال_صحيح(
	"ادخل عدد لعبات التدريب ليتم توليدها(ملاحظة: 15 سريع, 250 جودة تدريب عالية) [القيمة الإفتراضية 15]: "
	, 15)
عدد_الفترات = اجلب_ادخال_صحيح(
	"ادخل اقصى فترات للتدريب (ملاحظة: 160-360 تعتبر أفضل قيم لخسارة أقل) [القيمة الإفتراضية 160]: "
	, 160)

بيانات_التدريب = توليد_بيانات_التدريب(عدد_لعبات_التدريب)

شبكة_مدربة = درب_الشبكة(بيانات_التدريب, عدد_الفترات)

بينما صح:
	العب(شبكة_مدربة)
	اذا ادخل("\سهل تريد اللعب مرة اخرى؟ (نعم/لا): ") != "نعم":
		توقف
