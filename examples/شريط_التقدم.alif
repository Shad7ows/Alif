# هذا البرنامج يقوم بعرض طريقة إنشاء شريط التقدم #
استورد الوقت

دالة شريط_التقدم(السابقة="", اللاحقة="", الطول=50, ملء="█"):
	لكل ص في مدى(الطول):
		ملء += "█"
		اطبع(م"\ر{السابقة} |{ملء:░<{الطول+1}}| {اللاحقة} {ص*2}%", النهاية="", دفق=صح)
		الوقت.غفوة(0.07)
	اطبع()

اطبع("جاري تحميل الملف ...")		
شريط_التقدم(السابقة="التقدم:", اللاحقة="اكتمل", الطول=51)
اطبع("إكتمل التحميل بنجاح.")