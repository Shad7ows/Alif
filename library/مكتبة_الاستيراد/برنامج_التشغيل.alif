
# المحملات ##########################################################
صنف مستورد_الضمنيات:
	دالة __تهيئة__(هذا):
		مرر


_يحتاج_تحميل = كائن()

دالة _اوجد_وحمل(الاسم, استيراد_):
	وحدة = النظام.وحدات.احضر(الاسم, _يحتاج_تحميل)
	
	
	
	ارجع وحدة


دالة _اضبط(وحدة_نظام, _وحدة_ورد):
	عام _ورد, النظام
	_ورد = _وحدة_ورد
	النظام = وحدة_نظام

دالة _ثبت(وحدة_نظام, _وحدة_ورد):
	_اضبط(وحدة_نظام, _وحدة_ورد)
	
	النظام.مسار_التعريف.اضف(مستورد_الضمنيات)
